{
  "name": "fbx-quick-viewer",
  "version": "1.0.5",
  "description": "3D FBX Viewer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node tests/mesh-path-resolution.test.js && node tests/v1.0.5-uv-controls.test.js && node tests/v1.0.5-max-navigation.test.js && node tests/v1.0.5-discoverability.test.js && node tests/drag-drop-behavior.test.js && node tests/v1.0.4-features.test.js && node tests/electron-smoke.test.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Cherofre",
  "license": "ISC",
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.viewer.fbx",
    "files": [
      "main.js",
      "mesh-path.js",
      "preload.js",
      "index.html",
      "icon.png",
      "ViewCube.js",
      "libs/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
