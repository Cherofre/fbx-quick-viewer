{
  "name": "fbx-quick-viewer",
  "version": "1.0.2",
  "description": "3D FBX Viewer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prepare:release": "node scripts/prepare-dist.js",
    "pack": "npm run prepare:release && electron-builder --dir",
    "dist": "npm run prepare:release && electron-builder"
  },
  "author": "YourName",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.viewer.fbx",
    "compression": "normal",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
